# 全局配置 
global {
    tproxy_port:"12345"
    tproxy_port_protect:"true"
    so_mark_from_dae:"0"
    log_level:"info"
    tcp_check_url:"http://cp.cloudflare.com,1.1.1.1,2606:4700:4700::1111"
    tcp_check_http_method:"HEAD"
    udp_check_dns:"dns.google:53,8.8.8.8,2001:4860:4860::8888"
    check_interval:"30s"
    check_tolerance:"50ms"
    lan_interface:"ens3"
    wan_interface:"auto"
    allow_insecure:"false"
    dial_mode:"domain"
    disable_waiting_network:"false"
    enable_local_tcp_fast_redirect:"false"
    auto_config_kernel_parameter:"true"
    auto_config_firewall_rule:"false"
    sniffing_timeout:"30ms"
    tls_implementation:"tls"
    utls_imitate:"chrome_auto"
    tls_fragment:"false"
    tls_fragment_length:"50-100"
    tls_fragment_interval:"10-20"
    pprof_port:"0"
    mptcp:"false"
    fallback_resolver:"223.5.5.5:53"
    bandwidth_max_tx:"200 mbps"
    bandwidth_max_rx:"1 gbps"
    udphop_interval:"30s"
}

# 订阅配置
subscription {
    Yifen: 'https://yaml2link.664478124.xyz/sub?url=https://yfjc.xyz/api/v1/client/subscribe?token=9d0d88189b137f5c8df79d6e79a8f3a7'
    Feiniao: 'https://yaml2link.664478124.xyz/sub?url=https://b33ce253.684821.xyz/api/v1/client/subscribe?token=77afff4bb77e7bc5da46dbb0ff0e4d85'
}

# 节点配置
node {
    CF_ECH: 'http://10.0.0.6:5412'
}

# DNS配置 | 完整示例请参见： https://github.com/daeuniverse/dae/blob/main/docs/zh/configuration/dns.md
dns {
    upstream {
        alidns: 'https://dns.alidns.com:443'
        googledns: 'tcp+udp://8.8.8.8:53'
    }
    routing {
        request {
            qname(geosite:category-ads) -> reject
            qname(geosite:google-play) -> googledns
            qname(geosite:wikimedia) -> alidns
            qname(suffix:xn--4gqx1hgtfdmt.com) -> alidns
            qname(geosite:cn) -> alidns
            fallback: googledns
        }
        response {
            upstream(googledns) -> accept
            ip(geoip:private) && !qname(geosite:cn) -> googledns
            fallback: accept
        }
    }
}

# 节点组（出站）
group {
    Ai {
        policy: min_avg10
        filter: subtag(Feiniao) && name(keyword: '台湾', keyword: '新加坡', keyword: '美国')
    }
    Google {
        policy: min_moving_avg
        filter: subtag(Feiniao)
        filter: name(CF_ECH)
    }
    Youtube {
        policy: min_moving_avg
        filter: subtag(Yifen)
        filter: name(CF_ECH)
    }
    proxy {
        policy: min_moving_avg
        filter: subtag(Yifen)
        filter: name(CF_ECH)
    }
}

# 路由配置 | 完整示例请参见： https://github.com/daeuniverse/dae/blob/main/docs/zh/configuration/routing.md
routing {
    pname(NetworkManager, systemd-resolved, dnsmasq) -> must_direct
    l4proto(udp) && dport(443) -> block
    dip(geoip:private) -> direct
    domain(geosite:category-ads) -> block
    domain(
    suffix: 664478124.xyz,
    suffix: chaipip.com,
    suffix: snapdrop.net,
    suffix: macapp.so,
    suffix: 404world.in,
    suffix: go-cqhttp.org,
    suffix: nonebot.dev,
    suffix: napneko.com,
    suffix: key-test.com,
    suffix: remove.bg,
    suffix: ooopn.com,
    suffix: checkadblock.ru,
    suffix: subhd.tv,
    suffix: gyg.si,
    suffix: digitalplat.org,
    suffix: test-ipv6.com,
    suffix: ra2web.com,
    suffix: longcat.chat,
    suffix: cloudflare-ech.com,
    suffix: ustc.edu.cn
    ) -> direct
    domain(geosite: openai, geosite: google-gemini, geosite:cloudflare) -> Ai
    domain(geosite: youtube) -> Youtube
    domain(geosite: google) -> Google
    domain(
    geosite: google-play,
    suffix: bit.no.com,
    suffix: unsplash.com,
    suffix: sanfen.cc,
    suffix: xn--4gqx1hgtfdmt.com,
    suffix: appstorrent.ru,
    suffix: qichiyu.com,
    suffix: feiniaoyun.xyz,
    geosite: geolocation-!cn
    ) -> proxy
    dip(geoip:cn) -> direct
    domain(geosite:cn) -> direct
    fallback: proxy
}